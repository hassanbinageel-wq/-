<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:layoutDirection="rtl"
    android:background="@drawable/bg_alarm_gradient"
    android:padding="28dp">

    <ImageView
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_moon"
        android:contentDescription="moon" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="حان وقت الصلاة"
        android:textColor="@color/gold"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvAlarmLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="@color/text_primary"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/tvClock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="00:00"
        android:textColor="@color/gold_light"
        android:textSize="58sp"
        android:textStyle="bold"
        android:fontFeatureSettings="tnum" />

    <FrameLayout
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_circle_outline">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenCamera"
            android:layout_width="118dp"
            android:layout_height="118dp"
            android:layout_gravity="center"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="60dp"
            app:backgroundTint="@color/gold"
            app:icon="@drawable/ic_camera"
            app:iconTint="@color/black"
            app:iconSize="52dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:contentDescription="افتح الكاميرا" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:gravity="center"
        android:text="صوّر المغسلة أو الصنبور لإيقاف المنبّه"
        android:textColor="@color/text_primary"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="المنبّه ما يطفّى إلا بالكاميرا 🚿"
        android:textColor="@color/text_muted"
        android:textSize="14sp" />

</LinearLayout>
